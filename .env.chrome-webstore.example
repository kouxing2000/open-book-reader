# Chrome Web Store API Credentials  (Open Book Reader)
# Copy this file to .env.chrome-webstore and fill in your values.
# .env.chrome-webstore is gitignored - never commit real credentials.

# ==============================================================================
# STEP 1: Get your Extension ID
# ==============================================================================
# After the first manual upload, find it in the Developer Dashboard / store URL.
CHROME_EXTENSION_ID=your-extension-id-here

# ==============================================================================
# STEP 2: Get OAuth Client ID & Secret from Google Cloud Console
# ==============================================================================
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create a project and enable "Chrome Web Store API"
# 3. Create OAuth 2.0 Client ID (type: Desktop app OR Web application)
# 4. If Web application, add redirect URI: http://localhost:8123/oauth2callback
# 5. Copy your Client ID and Secret below:
CHROME_CLIENT_ID=your-client-id.apps.googleusercontent.com
CHROME_CLIENT_SECRET=your-client-secret

# ==============================================================================
# STEP 3: Generate Refresh Token (AUTOMATIC)
# ==============================================================================
# You DON'T need to set this manually.
# Just run: npm run get-token
# It opens your browser for consent and writes the token back here.
#
# CHROME_REFRESH_TOKEN=will-be-generated-automatically

# ==============================================================================
# Optional Settings
# ==============================================================================
# Auto-publish after upload (default: true). Set 'false' to upload only and
# publish manually from the Developer Dashboard.
AUTO_PUBLISH=true
